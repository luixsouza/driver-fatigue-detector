%%
%% sbc-template.sty
%% Estilo SBC duas colunas, 10pt, A4
%% Compatível com: \documentclass[10pt,a4paper,twocolumn]{article}
%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sbc-template}[2026/05/19 SBC Template v4.0 two-column]

\RequirePackage{times}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{url}
\RequirePackage{color}

%%----------------------------------------------------------------------
%% Geometria A4 — margens 25mm (texto 160 x 247 mm)
%%----------------------------------------------------------------------
\setlength{\paperheight}{297mm}
\setlength{\paperwidth}{210mm}

\setlength{\textwidth}{160mm}
\setlength{\textheight}{247mm}
\setlength{\oddsidemargin}{-1mm}   % 25mm - 1in = -1mm
\setlength{\evensidemargin}{-1mm}
\setlength{\topmargin}{-26mm}      % 25mm - 1in
\setlength{\headheight}{0mm}
\setlength{\headsep}{0mm}
\setlength{\columnsep}{6mm}
\setlength{\parindent}{4mm}
\setlength{\parskip}{2pt}

\setlength{\abovecaptionskip}{3pt}
\setlength{\belowcaptionskip}{3pt}

%%----------------------------------------------------------------------
%% Section headings — bold, compactos
%%----------------------------------------------------------------------
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-10pt \@plus -2pt \@minus -2pt}%
  {4pt \@plus 1pt}%
  {\normalfont\large\bfseries}}

\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-8pt \@plus -1pt \@minus -1pt}%
  {3pt \@plus 1pt}%
  {\normalfont\normalsize\bfseries}}

\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-6pt \@plus -1pt \@minus -1pt}%
  {2pt \@plus 1pt}%
  {\normalfont\normalsize\itshape}}

%%----------------------------------------------------------------------
%% Autores, instituição, e-mail
%%----------------------------------------------------------------------
\newcommand{\inst}[1]{\unskip$^{#1}$}
\newcommand{\email}[1]{\texttt{#1}}

\gdef\@address{}
\newcommand{\address}[1]{\gdef\@address{#1}}

%%----------------------------------------------------------------------
%% \maketitle — bloco do título spanning ambas colunas
%%----------------------------------------------------------------------
\renewcommand{\maketitle}{%
  \twocolumn[%
    \begin{@twocolumnfalse}%
    \@maketitle
    \end{@twocolumnfalse}%
  ]%
  \thispagestyle{empty}%
  \pagestyle{empty}%
  \setcounter{footnote}{0}%
}

\newcommand{\@maketitle}{%
  \begin{center}%
    {\Large \bfseries \@title \par}%
    \vskip 8pt%
    {\normalsize \@author \par}%
    \vskip 4pt%
    {\small \@address \par}%
  \end{center}%
  \vskip 10pt%
}

%%----------------------------------------------------------------------
%% abstract (inglês) e resumo (português) — uma coluna
%%----------------------------------------------------------------------
\renewenvironment{abstract}{%
  \small
  \noindent\textbf{Abstract.}\space\ignorespaces
}{%
  \par\vskip 4pt%
}

\newenvironment{resumo}{%
  \small
  \noindent\textbf{Resumo.}\space\ignorespaces
}{%
  \par\vskip 4pt%
}

%%----------------------------------------------------------------------
%% Captions — pequenas e compactas
%%----------------------------------------------------------------------
\long\def\@makecaption#1#2{%
  \vskip\abovecaptionskip
  \sbox\@tempboxa{\small\textbf{#1.} #2}%
  \ifdim \wd\@tempboxa >\hsize
    \small\textbf{#1.} #2\par
  \else
    \global \@minipagefalse
    \hb@xt@\hsize{\hfil\box\@tempboxa\hfil}%
  \fi
  \vskip\belowcaptionskip}

%%----------------------------------------------------------------------
%% Bibliografia — fonte pequena
%%----------------------------------------------------------------------
\renewcommand{\@biblabel}[1]{[#1]}

\renewenvironment{thebibliography}[1]{%
  \section*{\refname}%
  \small
  \list{\@biblabel{\@arabic\c@enumiv}}{%
    \settowidth\labelwidth{\@biblabel{#1}}%
    \leftmargin\labelwidth
    \advance\leftmargin\labelsep
    \@openbib@code
    \usecounter{enumiv}%
    \let\p@enumiv\@empty
    \renewcommand\theenumiv{\@arabic\c@enumiv}}%
  \sloppy
  \clubpenalty4000
  \@clubpenalty \clubpenalty
  \widowpenalty4000%
  \sfcode`\.\@m}
{\def\@noitemerr
  {\@latex@warning{Empty `thebibliography' environment}}%
  \endlist}

\endinput
%%
%% Fim de sbc-template.sty
